# Root workspace environment
NODE_ENV=development

# Shared local infrastructure
DATABASE_URL=postgresql://career_pilot:career_pilot@localhost:5432/career_pilot
REDIS_URL=redis://localhost:6379

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1

# API
API_PORT=4000
APP_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ACCESS_TOKEN_SECRET=replace-me
REFRESH_TOKEN_SECRET=replace-me-too
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Worker
WORKER_CONCURRENCY=5
