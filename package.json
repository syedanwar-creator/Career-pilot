{
  "name": "career-pilot",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "description": "Career Pilot production monorepo scaffold with legacy prototype preserved for reference",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev-workspace.mjs",
    "dev:web": "pnpm --filter @career-pilot/web dev",
    "dev:api": "pnpm --filter @career-pilot/api dev",
    "dev:worker": "pnpm --filter @career-pilot/worker dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "infra:docker": "docker compose up -d postgres redis",
    "infra:local:start": "sh scripts/start-local-infra.sh",
    "infra:local:stop": "sh scripts/stop-local-infra.sh",
    "setup:local": "sh scripts/local-bootstrap.sh",
    "legacy:dev": "node scripts/dev.js",
    "legacy:start": "node server.js",
    "legacy:server": "node server.js",
    "legacy:client": "vite",
    "legacy:build": "tsc -b && vite build",
    "legacy:preview": "vite preview",
    "legacy:typecheck": "tsc -b"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^4.1.2",
    "react-router-dom": "^6.30.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^20.17.57",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.19"
  }
}
