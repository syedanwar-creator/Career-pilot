generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantType {
  school
}

enum TenantStatus {
  active
  suspended
}

enum UserAccountType {
  individual
  tenant_member
}

enum UserStatus {
  active
  invited
  disabled
}

enum MembershipRole {
  school_admin
  student
  parent_viewer
}

enum MembershipStatus {
  active
  revoked
}

enum AuditActorType {
  user
  system
}

enum ProfileCompletionStatus {
  draft
  submitted
}

enum CareerStatus {
  draft
  active
  archived
}

enum ProofSessionStatus {
  in_progress
  completed
}

enum ReportType {
  student
  school
}

enum ReportStatus {
  queued
  ready
  failed
}

model Tenant {
  id          String             @id @default(uuid()) @db.Uuid
  name        String
  slug        String             @unique
  type        TenantType         @default(school)
  status      TenantStatus       @default(active)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  memberships TenantMembership[]
  auditLogs   AuditLog[]
  studentProfiles StudentProfile[]
  proofSessions   ProofSession[]
  reports         Report[]
}

model User {
  id                  String               @id @default(uuid()) @db.Uuid
  email               String               @unique
  passwordHash        String
  fullName            String
  accountType         UserAccountType
  status              UserStatus           @default(active)
  memberships         TenantMembership[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]
  studentProfile      StudentProfile?
  recommendationSnapshots RecommendationSnapshot[]
  proofSessions       ProofSession[]
  reports             Report[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model TenantMembership {
  id        String           @id @default(uuid()) @db.Uuid
  tenantId  String           @db.Uuid
  userId    String           @db.Uuid
  role      MembershipRole
  status    MembershipStatus @default(active)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AuditLog {
  id           String         @id @default(uuid()) @db.Uuid
  actorType    AuditActorType @default(user)
  actorUserId  String?        @db.Uuid
  tenantId     String?        @db.Uuid
  action       String
  entityType   String
  entityId     String?
  metadata     Json?
  ipAddress    String?
  createdAt    DateTime       @default(now())
  actorUser    User?          @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  tenant       Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
}

model CareerCategory {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  careers   Career[]
}

model Career {
  id            String       @id @default(uuid()) @db.Uuid
  categoryId    String       @db.Uuid
  slug          String       @unique
  title         String
  summary       String
  status        CareerStatus @default(active)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  category      CareerCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  detail        CareerDetail?
  proofSessions ProofSession[]

  @@index([categoryId, status])
}

model CareerDetail {
  id              String   @id @default(uuid()) @db.Uuid
  careerId        String   @unique @db.Uuid
  educationPath   Json
  skills          Json
  positives       Json
  challenges      Json
  drawbacks       Json
  salaryMeta      Json
  outlookMeta     Json
  resilienceMeta  Json
  updatedAt       DateTime @updatedAt
  career          Career   @relation(fields: [careerId], references: [id], onDelete: Cascade)
}

model StudentProfile {
  id                 String                  @id @default(uuid()) @db.Uuid
  userId             String                  @unique @db.Uuid
  tenantId           String?                 @db.Uuid
  gradeLevel         String?
  ageBand            String?
  favoriteSubjects   Json?
  favoriteActivities Json?
  topicsCuriousAbout Json?
  personalStrengths  Json?
  avoidsOrDislikes   Json?
  completionStatus   ProfileCompletionStatus @default(draft)
  submittedAt        DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant             Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  versions           ProfileVersion[]
  recommendationSnapshots RecommendationSnapshot[]
  proofSessions      ProofSession[]

  @@index([tenantId])
}

model ProfileVersion {
  id               String         @id @default(uuid()) @db.Uuid
  studentProfileId String         @db.Uuid
  createdByUserId  String         @db.Uuid
  snapshot         Json
  createdAt        DateTime       @default(now())
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([studentProfileId, createdAt])
}

model RecommendationSnapshot {
  id                  String         @id @default(uuid()) @db.Uuid
  userId              String         @db.Uuid
  studentProfileId    String         @db.Uuid
  engineVersion       String
  profileVersionCount Int
  itemsJson           Json
  inputSummary        Json?
  createdAt           DateTime       @default(now())
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentProfile      StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([studentProfileId, createdAt])
}

model ProofSession {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String             @db.Uuid
  tenantId           String?            @db.Uuid
  careerId           String             @db.Uuid
  studentProfileId   String             @db.Uuid
  status             ProofSessionStatus @default(in_progress)
  questionSource     String
  scoringSource      String?
  questionSetVersion String
  questionSetJson    Json
  answerSetJson      Json?
  resultJson         Json?
  overallScore       Int?
  points             Int?
  readinessBand      String?
  startedAt          DateTime           @default(now())
  completedAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant             Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  career             Career             @relation(fields: [careerId], references: [id], onDelete: Cascade)
  studentProfile     StudentProfile     @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([careerId, createdAt])
  @@index([studentProfileId, createdAt])
}

model Report {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @db.Uuid
  tenantId  String?      @db.Uuid
  reportType ReportType
  status    ReportStatus @default(queued)
  version   String
  reportJson Json?
  fileUrl   String?
  errorMessage String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  shares    ReportShare[]

  @@index([userId, reportType, createdAt])
  @@index([tenantId, reportType, createdAt])
}

model ReportShare {
  id         String    @id @default(uuid()) @db.Uuid
  reportId   String    @db.Uuid
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  report     Report    @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
  @@index([expiresAt])
}
